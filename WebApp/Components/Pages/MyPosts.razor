@page "/my-posts"
@using WebApp
@* הזרקת השירות לניהול המשתמש המחובר *@
@inject LoginService loginService
@* הזרקת שירות הניווט בין דפים *@
@inject NavigationManager Nav

@* חובה להוסיף כדי שקישור הנתונים והפעולות יעבדו *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="container mt-4 text-end" dir="rtl">

    @if (loggedUser != null)
    {
        @* סרגל כלים עליון עם כפתורי ניווט והצגת שם המשתמש המחובר *@
        <div class="alert alert-light border d-flex justify-content-between align-items-center mb-4">
            @* הצגת שם המשתמש מתוך העצם שנשלף בטעינת הדף *@
            <h2 class="m-0">הפוסטים שלי - @loggedUser.FullName</h2>
            <div>
                @* כפתורי ניווט וניהול בצבעים שונים להבחנה מהירה *@
                <a href="/add-post" class="btn btn-success me-2">הוסף פוסט חדש</a>
                <a href="/posts" class="btn btn-info me-2">תצוגת גלריה</a>
                @* כפתור תצוגת טבלה בצבע כחול כדי להבדילו מתצוגת הגלריה *@
                <a href="/posts-table" class="btn btn-primary me-2">תצוגת טבלה</a>
                <button class="btn btn-danger" @onclick="HandleLogout">יציאה</button>
            </div>
        </div>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>תוכן</th>
                    <th>תמונה</th>
                    <th>ניהול פוסט</th>
                </tr>
            </thead>
            <tbody>
                @foreach (PostWithAuthor item in myPosts)
                {
                    <tr>
                        <td>@item.Text</td>
                        <td><img src="@item.ImageUrl" style="width:100px;" /></td>
                        <td>
                            @* כפתורי ניהול המופיעים רק עבור הפוסטים האישיים של המשתמש *@
                            <a href="/edit-post/@item.Id" class="btn btn-warning btn-sm me-2">עריכה</a>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeletePost(item.Id)">מחיקה</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    List<PostWithAuthor> myPosts = new List<PostWithAuthor>();
    User loggedUser;
    PostService ps = new PostService();

    @* פעולה המופעלת באופן אוטומטי בעת טעינת הדף *@
    protected override async Task OnInitializedAsync()
    {
        @* שליפת העצם של המשתמש המחובר מהשירות *@
        loggedUser = await loginService.GetLoggedUser();

        @* בדיקת אבטחה: במידה והמשתמש לא מחובר נבצע הפניה לדף הכניסה *@
        if (loggedUser == null)
        {
            Nav.NavigateTo("/");
            return;
        }

        @* טעינת הפוסטים המשוייכים למזהה המשתמש מתוך העצם המחובר *@
        myPosts = ps.GetPostsByUserId(loggedUser.Id);
    }

    @* פעולה המוחקת פוסט ומעדכנת את הרשימה *@
    private void DeletePost(int postId)
    {
        @* הפעלת פעולת המחיקה במסד הנתונים *@
        ps.DeletePost(postId);

        @* טעינה מחדש של הרשימה המסוננת עבור המשתמש *@
        myPosts = ps.GetPostsByUserId(loggedUser.Id);
    }

    @* פעולה המנתקת את המשתמש ומחזירה אותו לדף הכניסה *@
    private async Task HandleLogout()
    {
        @* ביצוע פעולת ניתוק דרך השירות וחזרה לשער הכניסה *@
        await loginService.Logout();
        Nav.NavigateTo("/");
    }
}