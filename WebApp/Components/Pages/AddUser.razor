@page "/add-user"
@using WebApp
@inject NavigationManager Nav

@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="container mt-5 text-end" dir="rtl">
    <h3>דף הרשמה למערכת</h3>
    <p>מלאו את הפרטים כדי להצטרף לרשת החברתית:</p>

    @* שדות קלט להרשמה המקושרים לשדות בעצם המשתמש *@
    <div class="mb-3">
        <label>שם מלא:</label>
        <input class="form-control" @bind-value="user.FullName" />
    </div>

    <div class="mb-3">
        <label>שם משתמש:</label>
        <input class="form-control" @bind-value="user.UserName" />
    </div>

    <div class="mb-3">
        <label>אימייל:</label>
        <input class="form-control" @bind-value="user.Email" />
    </div>

    <div class="mb-3">
        <label>סיסמה:</label>
        <input type="password" class="form-control" @bind-value="user.Password" />
    </div>

    @* לחיצה על הכפתור תשמור את המשתמש ותחזיר אותו לדף הכניסה *@
    <button class="btn btn-success" @onclick="HandleRegister">סיום הרשמה</button>
    <a href="/" class="btn btn-link">כבר יש לי משתמש</a>
</div>

@code {
    // יצירת עצם משתמש חדש שיכיל את הנתונים מהשדות
    User user = new User();
    UserService service = new UserService();

    public void HandleRegister()
    {
        // שמירת המשתמש החדש במסד הנתונים באמצעות השירות
        service.AddNewUser(user);

        // לאחר ההרשמה, נעבור לדף הכניסה כדי שהמשתמש יוכל להתחבר
        Nav.NavigateTo("/");
    }
}