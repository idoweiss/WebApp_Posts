@page "/add-user"
@using WebApp
@inject LoginService loginService
@inject NavigationManager Nav
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@* מודאים שרק מנהל המערכת יכול לבצע שינויים במשתמשי המערכת *@
@if (loggedUser != null && loggedUser.UserName == "admin")
{
    <h3>AddUser</h3>

    @* --- הוספת משתמש --- *@
    @* שדות קלט להוספת משתמש - מקושרים למשתנים ייעודיים להוספה *@

    @* שדה שם *@
    <text>Name:</text>
    <input @bind-value="user.FullName" />
    <p></p>

    @* שדה שם משתמש *@
    <text>User Name:</text>
    <input @bind-value="user.UserName" />
    <p></p>

    @* שדה אמייל *@
    <text>Email:</text>
    <input @bind-value="user.Email" />
    <p></p>

    @* שדה סיסמה *@
    <text>Password:</text>
    <input type="password" @bind-value="user.Password" />
    <p></p>

    @* כפתור להוספת משתמש *@
    <button class="btn btn-primary" @onclick="SaveUser">Add User</button>
}

@code {
    User user = new User();
    User loggedUser;
    UserService service = new UserService();

    protected override async Task OnInitializedAsync()
    {
        loggedUser = await loginService.GetLoggedUser();
        //מודאים שרק מנהל המערכת יכול לבצע שינויים במשתמשי המערכת
        if (loggedUser == null || loggedUser.UserName != "admin")
        {
            Nav.NavigateTo("/");
            return;
        }
    }

    public void SaveUser()
    {
        service.AddNewUser(user);
        Nav.NavigateTo("/users");
    }
}